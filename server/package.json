{
  "name": "spotaclone-downloader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local companion server that downloads audio from YouTube/Spotify links for the Spotaclone app (using yt-dlp + ffmpeg).",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "postinstall": "node scripts/setup.mjs",
    "start": "node src/index.js",
    "dev": "node --env-file-if-exists=.env --watch src/index.js",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "ffmpeg-static": "^5.2.0",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
