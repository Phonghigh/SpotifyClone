# EAS Build uploads your project as a tarball before building — anything
# matched here is excluded from that upload. Note: once this file exists,
# EAS stops reading .gitignore for upload purposes, so the usual excludes
# are repeated here.

# dependencies (installed fresh on the EAS builder)
node_modules/

# the companion downloader server is a separate app with its own
# eas.json/app.json — irrelevant to this Expo app's build and large
# (its own node_modules, bundled yt-dlp/ffmpeg binaries)
server/

# Expo / Metro
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# generated native projects (regenerated by prebuild / EAS)
/ios
/android

# native build leftovers
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# OS/editor cruft
.DS_Store
*.pem
.vscode/
.claude/
.git/

# local env / secrets — EAS Build reads env vars from `eas env:create`, not
# from an uploaded .env file, so this is safe (and desired) to exclude
.env
.env*.local

# typescript
*.tsbuildinfo

# docs (not needed to build)
README.md
LICENSE
