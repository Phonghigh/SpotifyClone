# Copy to `.env` (gitignored) and fill in real values.
# These are inlined into the JS bundle at build time by Expo — see src/config.ts.

# Must match the API_KEY env var set on your server (Render dashboard, or local server/.env).
EXPO_PUBLIC_API_KEY=

# Optional: your PC's LAN IP + port for "Local (Wi-Fi)" server mode, e.g. http://192.168.1.23:4000.
# Leave blank to type it in the app instead.
EXPO_PUBLIC_LOCAL_SERVER_URL=
